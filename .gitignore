# Dependencies — regenerated by `python eido.py bootstrap` (deno + deno.lock)
node_modules/

# Agent scratch space + run outputs
work/
runs/

# Per-run brief/context/capabilities handshake files (written by eido.py)
_brief.txt
_context.txt
_capabilities.json

# Python bytecode
__pycache__/
*.pyc

# Render byproducts
*.log
qc_frames/

# eido.py render --probe artifacts
*_probe.json
*_probe.mp4

# Rendered example outputs + review frames (regenerate via eido.py render)
eidoverse/examples/*.mp4
eidoverse/examples/*.png
